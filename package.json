{
  "name": "bx-portfolio",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint src scripts",
    "test": "npm run smoke:source",
    "check": "npm run lint && npm run test",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build && pagefind --site dist",
    "build:vercel": "npm run build",
    "preview": "astro preview",
    "sync": "astro sync",
    "gallery:optimize": "node scripts/optimize-gallery.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "baidu:push": "node scripts/baidu-push.mjs",
    "baidu:push:force": "node scripts/baidu-push.mjs --force",
    "baidu:push:dry": "node scripts/baidu-push.mjs --dry-run",
    "lighthouse:collect": "lhci collect --config=./lighthouserc.json",
    "lighthouse:assert": "lhci assert --config=./lighthouserc.json",
    "lighthouse:ci": "npm run lighthouse:collect && npm run lighthouse:assert",
    "smoke:source": "node scripts/smoke-source.mjs",
    "smoke:dist": "node scripts/smoke-dist.mjs",
    "content:new": "node scripts/content-new.mjs",
    "content:check": "node scripts/content-check.mjs",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "prettier": "prettier --write **/*.{ts,tsx,js,jsx,css,md,mdx,json} --ignore-path .gitignore"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^7.1.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "lodash.kebabcase": "^4.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.19.2",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@lhci/cli": "^0.15.1",
    "@pagefind/default-ui": "^1.4.0",
    "@shikijs/transformers": "^4.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.55.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.3.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
