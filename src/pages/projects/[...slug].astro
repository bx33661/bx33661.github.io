---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import CrtShell from "@/components/CrtShell.astro";
import ProjectHero from "@/components/ProjectHero.astro";
import { SITE } from "@/config.ts";
import { getAllProjectsWithSlugs, type ProjectEntry } from "@/utils/projects";
import "@/styles/crt-projects.css";

export async function getStaticPaths() {
  const projects = await getAllProjectsWithSlugs();
  return projects.map(({ project, slug }, index) => ({
    params: { slug },
    props: {
      project,
      slug,
      workId: project.data.workId?.trim() || `WRK_${String(index + 1).padStart(3, "0")}`,
    },
  }));
}

type Props = {
  project: ProjectEntry;
  slug: string;
  workId: string;
};

const { project, workId } = Astro.props;
const { Content } = await render(project);
const currentUrl = Astro.url.toString();
---

<Layout
  title={`${project.data.title} | ${SITE.title}`}
  description={project.data.description}
  pubDatetime={project.data.pubDatetime}
  modDatetime={project.data.modDatetime}
  canonicalURL={currentUrl}
>
  <CrtShell active="projects">
    <main id="main-content" class="crt-frame">
      <a class="crt-back" href="/projects/">◀ BACK_TO_WORK</a>

      <article>
        <ProjectHero project={project} workId={workId} />
        <div class="crt-prose">
          <Content />
        </div>
      </article>
    </main>
  </CrtShell>
</Layout>
