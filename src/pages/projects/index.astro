---
import Layout from "@/layouts/Layout.astro";
import CrtShell from "@/components/CrtShell.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE } from "@/config.ts";
import { getAllProjectsWithSlugs } from "@/utils/projects";
import "@/styles/crt-projects.css";

const currentUrl = Astro.url.toString();
const projects = await getAllProjectsWithSlugs();
const pageDescription =
  "SELECTED_WORK — 安全研究与工程工具终端。选做的、可讲清的几件事。";

function formatWorkId(index: number, explicit?: string) {
  if (explicit?.trim()) return explicit.trim().toUpperCase();
  return `WRK_${String(index + 1).padStart(3, "0")}`;
}
---

<Layout
  title={`Projects | ${SITE.title}`}
  description={pageDescription}
  canonicalURL={currentUrl}
>
  <CrtShell active="projects">
    <main id="main-content" class="crt-frame">
      <div class="crt-section-label">
        -- SECTION 03 -----------------------------------------------
      </div>
      <h1 class="crt-title">SELECTED_WORK</h1>
      <div class="crt-meta">
        {projects.length} PROJECTS — SORTED BY ORDER ASC
      </div>

      {
        projects.length > 0 ? (
          <section class="crt-grid" aria-label="Selected work">
            {projects.map(({ project, slug }, index) => (
              <ProjectCard
                project={project}
                slug={slug}
                index={index}
                workId={formatWorkId(index, project.data.workId)}
              />
            ))}
            <a class="crt-more" href="https://github.com/bx33661" target="_blank" rel="noopener noreferrer">
              <div class="crt-more-title">SEE ALL ON GITHUB</div>
              <div class="crt-more-sub">github.com/bx33661</div>
              <div class="crt-more-arrow" aria-hidden="true">▶</div>
            </a>
          </section>
        ) : (
          <p class="crt-meta" style="margin-top:2rem">NO PROJECTS LOADED.</p>
        )
      }
    </main>
  </CrtShell>
</Layout>
