---
import Layout from "@/layouts/Layout.astro";
import CrtShell from "@/components/CrtShell.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE } from "@/config.ts";
import { getProjectRoots } from "@/utils/projects";
import "@/styles/crt-projects.css";

const currentUrl = Astro.url.toString();
const roots = await getProjectRoots();
const pageDescription =
  "Selected security research and tooling — each project is a small docs library.";

function formatWorkId(index: number, explicit?: string) {
  if (explicit?.trim()) return explicit.trim().toUpperCase();
  return `WRK_${String(index + 1).padStart(3, "0")}`;
}
---

<Layout
  title={`Projects | ${SITE.title}`}
  description={pageDescription}
  canonicalURL={currentUrl}
  chrome="crt"
>
  <CrtShell active="projects">
    <main id="main-content" class="crt-frame">
      <p class="crt-section-label">
        -- SECTION 03 -----------------------------------------------
      </p>
      <h1 class="crt-title">SELECTED_WORK</h1>
      <p class="crt-meta">
        {roots.length} PROJECTS — EACH IS A DOCS LIBRARY
      </p>

      {
        roots.length > 0 ? (
          <section class="crt-grid" aria-label="Selected work">
            {roots.map((doc, index) => (
              <ProjectCard
                project={doc.entry}
                slug={doc.hrefPath}
                index={index}
                workId={formatWorkId(index, doc.entry.data.workId)}
              />
            ))}
            <a
              class="crt-more"
              href="https://github.com/bx33661?tab=repositories"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="crt-more-title">SEE ALL PROJECTS</div>
              <div class="crt-more-sub">github.com/bx33661</div>
              <div class="crt-more-arrow" aria-hidden="true">
                ▶
              </div>
            </a>
          </section>
        ) : (
          <p class="crt-meta" style="margin-top:2rem">
            NO PROJECTS LOADED.
          </p>
        )
      }
    </main>
  </CrtShell>
</Layout>
