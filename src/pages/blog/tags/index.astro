---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { getTagPath } from "@/utils/tagPath";
import { SITE } from "@/config.ts";
import { getAllPosts } from "@/lib/data-utils";

const posts = await getAllPosts();

const tagsWithCount = getUniqueTags(posts)
  .map(({ tag, tagName }) => ({
    tag,
    tagName,
    count: getPostsByTag(posts, tag).length,
  }))
  .sort(
    (a, b) =>
      b.count - a.count || a.tagName.localeCompare(b.tagName, "zh-CN"),
  );

const maxCount = Math.max(...tagsWithCount.map((t) => t.count), 1);
const multiCount = tagsWithCount.filter((t) => t.count >= 2).length;
const singleCount = tagsWithCount.filter((t) => t.count === 1).length;

/** Map post count → visual weight 1–5 for the cloud. */
const levelOf = (count: number) => {
  if (maxCount <= 1) return 1;
  const t = count / maxCount;
  if (t >= 0.8) return 5;
  if (t >= 0.5) return 4;
  if (t >= 0.3) return 3;
  if (count >= 2) return 2;
  return 1;
};
---

<Layout
  title={`标签 | ${SITE.title}`}
  description="按主题浏览博客全部文章标签。"
  noindex={true}
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout tags-main">
    <header class="tags-head">
      <h1 class="tags-title">标签</h1>
      <p class="tags-desc">
        按主题浏览全部文章。字号越大，相关文章越多。
      </p>
      <p class="tags-meta">
        <span>{tagsWithCount.length} 个标签</span>
        <span aria-hidden="true">·</span>
        <span>{posts.length} 篇文章</span>
        <span aria-hidden="true">·</span>
        <span>{multiCount} 常用 / {singleCount} 单次</span>
      </p>
    </header>

    {
      tagsWithCount.length > 0 ? (
        <ul class="tag-cloud" role="list">
          {tagsWithCount.map(({ tag, tagName, count }) => (
            <li>
              <a
                href={getTagPath(tag)}
                transition:name={tag}
                class:list={[
                  "cloud-tag",
                  `lv-${levelOf(count)}`,
                  count === 1 && "is-once",
                ]}
                title={`${tagName} · ${count} 篇`}
              >
                <span class="cloud-hash" aria-hidden="true">
                  #
                </span>
                <span class="cloud-name">{tagName}</span>
                <span class="cloud-n">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="tags-empty">暂时还没有标签。</p>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  .tags-main {
    padding-bottom: 4rem;
  }

  .tags-head {
    margin: 0.25rem 0 1.75rem;
    max-width: 40rem;
  }

  .tags-title {
    margin: 0;
    font-size: clamp(1.85rem, 3.5vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--foreground);
  }

  .tags-desc {
    margin: 0.65rem 0 0;
    font-size: 0.98rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--foreground) 62%, transparent);
  }

  .tags-meta {
    margin: 0.85rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.55rem;
    font-family: var(--font-cartograph), ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--foreground) 42%, transparent);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.65rem 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cloud-tag {
    display: inline-flex;
    align-items: baseline;
    gap: 0.2rem;
    padding: 0.2rem 0.15rem;
    color: color-mix(in srgb, var(--foreground) 78%, transparent);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      opacity 0.15s ease;
  }

  .cloud-tag:hover,
  .cloud-tag:focus-visible {
    color: var(--accent);
    border-bottom-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .cloud-tag:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .cloud-hash {
    color: color-mix(in srgb, var(--accent) 70%, transparent);
    font-weight: 500;
    opacity: 0.85;
  }

  .cloud-name {
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .cloud-n {
    margin-left: 0.15rem;
    font-family: var(--font-cartograph), ui-monospace, monospace;
    font-size: 0.72em;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--foreground) 38%, transparent);
    vertical-align: super;
  }

  .cloud-tag:hover .cloud-n,
  .cloud-tag:focus-visible .cloud-n {
    color: color-mix(in srgb, var(--accent) 75%, transparent);
  }

  /* Count → size. Quiet scale, not poster sizes. */
  .lv-1 .cloud-name {
    font-size: 0.86rem;
    font-weight: 500;
  }
  .lv-2 .cloud-name {
    font-size: 0.95rem;
  }
  .lv-3 .cloud-name {
    font-size: 1.08rem;
  }
  .lv-4 .cloud-name {
    font-size: 1.22rem;
  }
  .lv-5 .cloud-name {
    font-size: 1.4rem;
    letter-spacing: -0.03em;
  }

  .lv-5 {
    color: var(--foreground);
  }

  .lv-4 {
    color: color-mix(in srgb, var(--foreground) 90%, transparent);
  }

  /* One-shot tags stay present but quieter — no separate ghetto section. */
  .is-once {
    opacity: 0.72;
  }

  .is-once:hover,
  .is-once:focus-visible {
    opacity: 1;
  }

  .tags-empty {
    margin: 2rem 0;
    color: color-mix(in srgb, var(--foreground) 55%, transparent);
  }

  @media (max-width: 480px) {
    .lv-5 .cloud-name {
      font-size: 1.22rem;
    }
    .lv-4 .cloud-name {
      font-size: 1.1rem;
    }
  }
</style>
