---
import type { GetStaticPaths } from "astro";
import { type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config.ts";
import { getAllPosts } from "@/lib/data-utils";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getAllPosts();
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const totalPosts = page.total;
const pageData = page.data as CollectionEntry<"blog">[];
---

<Layout
  title={`Blog | ${SITE.title}`}
  canonicalURL={Astro.url.toString()}
  noindex={page.currentPage > 1}
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout pb-4">
    <header class="blog-head">
      <h1 class="blog-title">Blog</h1>
      <p class="blog-desc">按时间浏览全部博客文章。</p>
      <p class="blog-meta">
        <span>{totalPosts} posts</span>
        {
          page.lastPage > 1 && (
            <>
              <span aria-hidden="true">·</span>
              <span>
                Page {page.currentPage}/{page.lastPage}
              </span>
            </>
          )
        }
      </p>
    </header>

    <ul>{pageData.map((data) => <Card {...data} />)}</ul>
  </main>

  <Pagination page={page as any} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<style>
  .blog-head {
    margin: 0.15rem 0 1.35rem;
    max-width: 40rem;
  }

  .blog-title {
    margin: 0;
    font-size: clamp(1.85rem, 3.5vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--foreground);
  }

  .blog-desc {
    margin: 0.55rem 0 0;
    font-size: 0.98rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--foreground) 62%, transparent);
  }

  .blog-meta {
    margin: 0.7rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.55rem;
    font-family: var(--font-cartograph), ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--foreground) 42%, transparent);
  }
</style>
