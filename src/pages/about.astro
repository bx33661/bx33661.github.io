---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config.ts";

const currentUrl = Astro.url.toString();

/** Right-rail thesis lines — short, stacked, no tag-cloud feel. */
const thesis = ["漏洞研究", "工程实践", "CTF · Build"];

const links = [
    {
        name: "GitHub",
        url: "https://github.com/bx33661",
        primary: true,
        external: true,
    },
    {
        name: "Projects",
        url: "/projects/",
        primary: true,
        external: false,
    },
    {
        name: "Email",
        url: "mailto:bx33661@gmail.com",
        primary: false,
        external: false,
    },
];
---

<Layout
    title="关于我"
    description="BX — 安全研究员与开发者。关注漏洞研究、工程实践与 CTF。"
    canonicalURL={currentUrl}
>
    <Header />

    <main id="main-content" class="about-page">
        <section class="about-hero" aria-label="关于 BX">
            <div class="about-glow" aria-hidden="true"></div>

            <div class="about-col about-col--left">
                <p class="about-kicker">About</p>
                <h1 class="about-title">{SITE.author || "BX"}</h1>
                <p class="about-role">安全研究员 · 开发者</p>
                <p class="about-bio">
                    一起见证星辰大海 ✨🌊🚀
                </p>
                <div class="about-actions">
                    {
                        links.map((link) => (
                            <a
                                href={link.url}
                                class:list={[
                                    "about-btn",
                                    link.primary && "about-btn--primary",
                                ]}
                                {...(link.external
                                    ? {
                                          target: "_blank",
                                          rel: "noopener noreferrer",
                                      }
                                    : {})}
                            >
                                {link.name}
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="about-col about-col--center">
                <div class="about-mark" aria-hidden="true">
                    <div class="about-mark-bloom"></div>
                    <img
                        src="/touxiang-512.png"
                        srcset="/touxiang-192.png 192w, /touxiang-512.png 512w"
                        sizes="188px"
                        alt=""
                        width="188"
                        height="188"
                        class="about-avatar"
                        loading="eager"
                        decoding="async"
                        fetchpriority="high"
                    />
                </div>
            </div>

            <div class="about-col about-col--right">
                <ul class="about-lines">
                    {
                        thesis.map((item) => (
                            <li class="about-line">{item}</li>
                        ))
                    }
                </ul>
                <p class="about-location">{SITE.location || "China"}</p>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .about-page {
        --about-ink: var(--foreground);
        --about-muted: color-mix(in srgb, var(--foreground) 56%, transparent);
        --about-faint: color-mix(in srgb, var(--foreground) 40%, transparent);
        --about-line: color-mix(in srgb, var(--foreground) 12%, transparent);
        --about-bloom: color-mix(in srgb, var(--accent) 34%, var(--background));
        position: relative;
        display: flex;
        flex: 1 1 auto;
        align-items: center;
        justify-content: center;
        /* Fill the viewport under sticky header; footer sits below without crowding. */
        min-height: calc(100svh - 5.5rem);
        padding: clamp(1.25rem, 3.5vw, 2.5rem) clamp(1.25rem, 5vw, 3.5rem)
            clamp(1.5rem, 4vw, 2.75rem);
        overflow: clip;
    }

    .about-hero {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        align-items: center;
        column-gap: clamp(1.25rem, 4vw, 3.25rem);
        width: min(1100px, 100%);
    }

    .about-glow {
        position: absolute;
        left: 50%;
        top: 50%;
        width: min(680px, 85vw);
        height: min(680px, 85vw);
        translate: -50% -50%;
        border-radius: 999px;
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--accent) 14%, transparent) 0%,
            color-mix(in srgb, var(--accent) 5%, transparent) 32%,
            transparent 70%
        );
        pointer-events: none;
        z-index: 0;
    }

    .about-col {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .about-col--left {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
        max-width: 26rem;
    }

    .about-col--center {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .about-col--right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: center;
        gap: 2rem;
        text-align: right;
        justify-self: end;
    }

    .about-kicker {
        margin: 0 0 1rem;
        font-family: var(--font-cartograph), ui-monospace, monospace;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
    }

    .about-title {
        margin: 0;
        font-size: clamp(3.6rem, 8.5vw, 5.75rem);
        font-weight: 700;
        letter-spacing: -0.06em;
        line-height: 0.9;
        color: var(--about-ink);
        text-wrap: balance;
    }

    .about-role {
        margin: 1rem 0 0;
        font-size: 1.02rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: var(--about-muted);
    }

    .about-bio {
        margin: 0.7rem 0 0;
        max-width: 22ch;
        font-size: 0.95rem;
        line-height: 1.65;
        color: var(--about-muted);
        text-wrap: pretty;
    }

    .about-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.45rem;
    }

    .about-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.55rem;
        padding: 0.6rem 1.15rem;
        border-radius: 999px;
        border: 1px solid var(--about-line);
        background: color-mix(in srgb, var(--background) 78%, transparent);
        color: var(--about-ink);
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        text-decoration: none;
        box-shadow: 0 1px 0 color-mix(in srgb, var(--foreground) 4%, transparent);
        transition:
            transform 0.18s ease,
            background-color 0.18s ease,
            border-color 0.18s ease,
            color 0.18s ease,
            box-shadow 0.18s ease;
    }

    .about-btn:hover {
        transform: translateY(-1px);
        border-color: color-mix(in srgb, var(--foreground) 20%, transparent);
        background: color-mix(in srgb, var(--foreground) 5%, var(--background));
    }

    .about-btn:focus-visible {
        outline: 2px dashed var(--accent);
        outline-offset: 3px;
    }

    .about-btn--primary {
        border-color: transparent;
        background: var(--foreground);
        color: var(--background);
        box-shadow: 0 12px 30px -16px
            color-mix(in srgb, var(--foreground) 55%, transparent);
    }

    .about-btn--primary:hover {
        background: color-mix(in srgb, var(--foreground) 90%, var(--accent));
        border-color: transparent;
        color: var(--background);
    }

    .about-mark {
        position: relative;
        display: grid;
        place-items: center;
        width: clamp(152px, 17vw, 188px);
        aspect-ratio: 1;
    }

    .about-mark-bloom {
        position: absolute;
        inset: -34%;
        border-radius: 999px;
        background: radial-gradient(
            circle,
            var(--about-bloom) 0%,
            color-mix(in srgb, var(--accent) 14%, transparent) 38%,
            transparent 72%
        );
        filter: blur(20px);
        opacity: 0.92;
        animation: about-breathe 8s ease-in-out infinite;
        will-change: transform, opacity;
    }

    .about-avatar {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        border-radius: 50%;
        object-fit: cover;
        background: var(--background);
        border: 1px solid color-mix(in srgb, var(--foreground) 8%, transparent);
        box-shadow:
            0 1px 0 color-mix(in srgb, var(--foreground) 5%, transparent),
            0 30px 64px -30px color-mix(in srgb, var(--foreground) 40%, transparent),
            0 0 0 12px color-mix(in srgb, var(--background) 72%, transparent);
    }

    .about-lines {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.95rem;
    }

    .about-line {
        font-family: var(--font-cartograph), ui-monospace, monospace;
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--about-faint);
        line-height: 1.35;
        white-space: nowrap;
    }

    .about-location {
        margin: 0;
        font-family: var(--font-cartograph), ui-monospace, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--foreground) 26%, transparent);
    }

    /* Quiet entrance — one orchestrated moment, not scattered motion. */
    @media (prefers-reduced-motion: no-preference) {
        .about-col--left,
        .about-col--center,
        .about-col--right {
            animation: about-rise 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        .about-col--center {
            animation-delay: 80ms;
        }

        .about-col--right {
            animation-delay: 140ms;
        }
    }

    @keyframes about-breathe {
        0%,
        100% {
            transform: scale(0.97);
            opacity: 0.78;
        }
        50% {
            transform: scale(1.04);
            opacity: 1;
        }
    }

    @keyframes about-rise {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        .about-page {
            min-height: auto;
            align-items: stretch;
            padding-top: 1.1rem;
            padding-bottom: 2rem;
        }

        .about-hero {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
            row-gap: 1.6rem;
        }

        .about-glow {
            width: min(480px, 115vw);
            height: min(480px, 115vw);
            top: 16%;
        }

        .about-col--left,
        .about-col--right {
            align-items: center;
            text-align: center;
            max-width: 28rem;
            justify-self: center;
        }

        .about-col--center {
            order: -1;
            padding-top: 0.35rem;
        }

        .about-bio {
            max-width: 28ch;
        }

        .about-actions {
            justify-content: center;
        }

        .about-lines {
            flex-direction: row;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: 0.45rem 0;
        }

        .about-line {
            letter-spacing: 0.12em;
            font-size: 0.7rem;
            white-space: normal;
        }

        .about-line:not(:last-child)::after {
            content: "·";
            margin: 0 0.7rem;
            opacity: 0.35;
            letter-spacing: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .about-mark-bloom {
            animation: none;
        }

        .about-btn,
        .about-col--left,
        .about-col--center,
        .about-col--right {
            animation: none;
            transition: none;
        }

        .about-btn:hover {
            transform: none;
        }
    }
</style>
