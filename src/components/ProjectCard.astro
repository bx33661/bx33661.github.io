---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type Props = {
  project: CollectionEntry<"projects">;
  slug: string;
  workId: string;
  index?: number;
};

const { project, slug, workId } = Astro.props;
const { title, description, tags, cover, category, pubDatetime, status } =
  project.data;

const year = pubDatetime.getFullYear();
const categoryLabel =
  category?.trim() ||
  `${status === "wip" ? "WIP" : status === "archived" ? "ARCHIVE" : "TOOLING"} — ${year}`;

const detailHref = `/projects/${slug}/`;
const displayTags = tags.slice(0, 4).map((t) => t.toUpperCase());
const monogram = title.trim().slice(0, 1).toUpperCase() || "P";
---

<a class="crt-card" href={detailHref} aria-label={`Open project ${title}`}>
  <div class="crt-card-media">
    {
      cover ? (
        <Image
          src={cover}
          alt=""
          widths={[640, 960, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
      ) : (
        <div class="crt-card-fallback" aria-hidden="true">
          <div class="crt-card-fallback-bar">
            <span>SESSION // {workId}</span>
            <span>{status.toUpperCase()}</span>
          </div>
          <div class="crt-card-fallback-title">
            <span style="opacity:0.55;margin-right:0.35rem">+</span>
            {title.toUpperCase()}
          </div>
          <div class="crt-card-fallback-grid">
            <div class="crt-card-fallback-cell" />
            <div class="crt-card-fallback-cell" />
            <div class="crt-card-fallback-cell" />
            <div class="crt-card-fallback-cell" />
            <div class="crt-card-fallback-cell" />
          </div>
          <div
            style="position:absolute;inset:auto 1.1rem 1rem auto;font-family:var(--font-crt-display);font-size:3rem;opacity:0.12;color:#f0d2a0"
          >
            {monogram}
          </div>
        </div>
      )
    }
    <div class="crt-card-scan" aria-hidden="true"></div>

    <div class="crt-card-hover">
      <div class="crt-card-id">{workId}</div>
      <p class="crt-card-desc">{description}</p>
      {
        displayTags.length > 0 && (
          <ul class="crt-tags">
            {displayTags.map((tag) => (
              <li class="crt-tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  <div class="crt-card-foot">
    <div>
      <h2 class="crt-card-name">{title}</h2>
      <div class="crt-card-cat">{categoryLabel}</div>
    </div>
    <div class="crt-card-year">{year}</div>
  </div>
</a>
