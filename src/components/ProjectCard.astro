---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type Props = {
  project: CollectionEntry<"projects">;
  slug: string;
  index?: number;
};

const { project, slug, index = 0 } = Astro.props;
const { title, description, tags, status, repo, cover } = project.data;

const statusLabel: Record<typeof status, string> = {
  active: "Active",
  wip: "WIP",
  archived: "Archived",
};

const monogram = title.trim().slice(0, 1).toUpperCase() || "P";
const detailHref = `/projects/${slug}/`;
---

<article class="pc" style={`--i:${index}`}>
  <a class="pc-main" href={detailHref} aria-label={`查看项目 ${title}`}>
    <div class="pc-cover">
      {
        cover ? (
          <Image
            src={cover}
            alt=""
            class="pc-cover-img"
            widths={[480, 720, 960]}
            sizes="(max-width: 640px) 100vw, 50vw"
            loading="lazy"
          />
        ) : (
          <div class="pc-cover-fallback" aria-hidden="true">
            <span class="pc-monogram">{monogram}</span>
          </div>
        )
      }
      <span class:list={["pc-status", `pc-status--${status}`]}>
        {statusLabel[status]}
      </span>
    </div>

    <div class="pc-body">
      <h2 class="pc-title">{title}</h2>
      <p class="pc-desc">{description}</p>
      {
        tags.length > 0 && (
          <ul class="pc-tags">
            {tags.map((tag) => (
              <li class="pc-tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </div>
  </a>

  <div class="pc-foot">
    <a
      class="pc-repo"
      href={repo}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${title} GitHub 仓库`}
    >
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"
        ></path>
      </svg>
      <span>GitHub</span>
      <svg class="pc-repo-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path
          d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5V7.5"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .pc {
    --pc-bg: color-mix(in srgb, var(--foreground) 3.5%, var(--background));
    --pc-border: color-mix(in srgb, var(--foreground) 10%, transparent);
    --pc-border-h: color-mix(in srgb, var(--accent) 35%, transparent);
    --pc-text-2: color-mix(in srgb, var(--foreground) 62%, transparent);
    --pc-text-3: color-mix(in srgb, var(--foreground) 42%, transparent);
    --pc-pill: color-mix(in srgb, var(--accent) 10%, var(--background));

    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--pc-border);
    background: var(--pc-bg);
    transition:
      border-color 0.22s ease,
      transform 0.22s ease,
      box-shadow 0.22s ease;
    animation: pc-in 0.45s ease both;
    animation-delay: calc(var(--i, 0) * 40ms);
  }

  .pc:hover {
    border-color: var(--pc-border-h);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .pc-main {
    display: flex;
    flex: 1;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }

  .pc-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: color-mix(in srgb, var(--accent) 8%, var(--background));
  }

  .pc-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pc-cover-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(
        120% 80% at 10% 0%,
        color-mix(in srgb, var(--accent) 22%, transparent),
        transparent 55%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--foreground) 6%, var(--background)),
        color-mix(in srgb, var(--accent) 8%, var(--background))
      );
  }

  .pc-monogram {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: color-mix(in srgb, var(--accent) 80%, var(--foreground));
    opacity: 0.9;
  }

  .pc-status {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    border-radius: 9999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
    background: color-mix(in srgb, var(--background) 78%, transparent);
    color: var(--pc-text-2);
  }

  .pc-status--active {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    color: color-mix(in srgb, var(--accent) 90%, var(--foreground));
  }

  .pc-status--wip {
    color: color-mix(in srgb, var(--foreground) 75%, transparent);
  }

  .pc-status--archived {
    opacity: 0.85;
  }

  .pc-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.1rem 0.75rem;
  }

  .pc-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--foreground);
    transition: color 0.2s ease;
  }

  .pc:hover .pc-title {
    color: var(--accent);
  }

  .pc-desc {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--pc-text-2);
  }

  .pc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .pc-tag {
    border-radius: 9999px;
    border: 1px solid var(--pc-border);
    background: var(--pc-pill);
    padding: 0.15rem 0.5rem;
    font-size: 0.6875rem;
    color: var(--pc-text-3);
  }

  .pc-foot {
    padding: 0 1.1rem 1rem;
  }

  .pc-repo {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 0.55rem;
    border: 1px solid var(--pc-border);
    padding: 0.4rem 0.65rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--pc-text-2);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .pc-repo:hover {
    border-color: var(--pc-border-h);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .pc-repo-arrow {
    opacity: 0.7;
  }

  @keyframes pc-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pc {
      animation: none;
    }

    .pc:hover {
      transform: none;
    }
  }
</style>
