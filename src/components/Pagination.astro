---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;

function withTrailingSlash(url: string | undefined): string | undefined {
  if (!url || url.endsWith("/")) return url;
  return `${url}/`;
}

const prevUrl = withTrailingSlash(page.url.prev);
const nextUrl = withTrailingSlash(page.url.next);
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-auto mb-8 flex justify-center"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <LinkButton
        disabled={!prevUrl}
        href={prevUrl as string}
        class:list={["me-4 select-none", { "opacity-50": !prevUrl }]}
        aria-label="Goto Previous Page"
      >
        <IconArrowLeft class="inline-block rtl:rotate-180" />
        Prev
      </LinkButton>
      {page.currentPage} / {page.lastPage}
      <LinkButton
        disabled={!nextUrl}
        href={nextUrl as string}
        class:list={["ms-4 select-none", { "opacity-50": !nextUrl }]}
        aria-label="Goto Next Page"
      >
        Next
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
