---
import {
  ENABLE_COMMENTS,
  GISCUS_CATEGORY,
  GISCUS_CATEGORY_ID,
  GISCUS_REPO,
  GISCUS_REPO_ID,
} from "@/config/env";
import { THEME_CHANGE_EVENT } from "@/config/theme";
import { SITE } from "@/config.ts";

const requiredConfig = {
  repo: GISCUS_REPO,
  repoId: GISCUS_REPO_ID,
  category: GISCUS_CATEGORY,
  categoryId: GISCUS_CATEGORY_ID,
} as const;

const missingConfig = Object.entries(requiredConfig)
  .filter(([, value]) => !value)
  .map(([key]) => key);

const isConfigured = missingConfig.length === 0;
const shouldRenderComments = ENABLE_COMMENTS && isConfigured;
const showDevNotice = ENABLE_COMMENTS && !isConfigured && import.meta.env.DEV;

const giscusConfig = {
  repo: GISCUS_REPO,
  repoId: GISCUS_REPO_ID,
  category: GISCUS_CATEGORY,
  categoryId: GISCUS_CATEGORY_ID,
  mapping: "pathname",
  strict: "0",
  reactionsEnabled: "1",
  emitMetadata: "0",
  inputPosition: "top",
  lang: SITE.lang,
  loading: "lazy",
} as const;
---

{
  shouldRenderComments && (
    <section id="comments" class="comments-panel mt-10 scroll-mt-24">
      <div class="mb-4 flex items-center gap-3" aria-hidden="true">
        <div class="h-px flex-1 bg-linear-to-r from-accent/20 via-border/30 to-transparent"></div>
        <span class="font-cartograph text-[10px] tracking-widest text-accent/35 uppercase select-none">
          // comments
        </span>
        <div class="h-px flex-1 bg-linear-to-r from-transparent via-border/30 to-accent/20"></div>
      </div>

      <div class="comments-shell rounded-3xl border border-border/20 bg-muted/10 px-4 py-5 shadow-sm shadow-black/5 backdrop-blur-sm sm:px-6">
        <div class="mb-4 flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold tracking-tight">评论区</h2>
            <p class="mt-1 text-sm text-foreground/60">
              使用 GitHub Discussions 驱动，欢迎留言交流。
            </p>
          </div>
        </div>

        <div data-giscus-host></div>
      </div>
    </section>
  )
}

{
  showDevNotice && (
    <section class="comments-panel mt-10">
      <div class="rounded-3xl border border-amber-500/20 bg-amber-500/8 px-4 py-4 text-sm text-foreground/70 sm:px-6">
        <p class="font-medium text-foreground/80">giscus 已开启，但配置还不完整。</p>
        <p class="mt-1">
          缺少这些环境变量：
          <span class="font-cartograph text-xs text-amber-700 dark:text-amber-300">
            {missingConfig.join(", ")}
          </span>
        </p>
      </div>
    </section>
  )
}

{
  shouldRenderComments && (
    <script
      is:inline
      define:vars={{ giscusConfig, themeChangeEvent: THEME_CHANGE_EVENT }}
      data-astro-rerun
    >
      (() => {
        const host = document.querySelector("[data-giscus-host]");
        if (!host) return;

        const commentsSection = host.closest(".comments-panel");
        if (!commentsSection) return;

        const storageKey = `bx:giscus:return:${window.location.pathname}`;
        let lastGiscusInteractionAt = 0;

        const markGiscusInteraction = () => {
          lastGiscusInteractionAt = Date.now();
        };

        const persistReturnPosition = () => {
          if (!lastGiscusInteractionAt) return;
          if (Date.now() - lastGiscusInteractionAt > 15000) return;

          window.sessionStorage.setItem(
            storageKey,
            JSON.stringify({
              path: window.location.pathname,
              scrollY: window.scrollY,
              ts: Date.now(),
            })
          );
        };

        const restoreReturnPosition = () => {
          const raw = window.sessionStorage.getItem(storageKey);
          if (!raw) return;

          window.sessionStorage.removeItem(storageKey);

          try {
            const saved = JSON.parse(raw);
            const isSamePage = saved?.path === window.location.pathname;
            const isFresh = Date.now() - Number(saved?.ts || 0) < 10 * 60 * 1000;
            const savedY = Number(saved?.scrollY);

            if (!isSamePage || !isFresh || Number.isNaN(savedY)) return;

            window.requestAnimationFrame(() => {
              window.scrollTo({
                top: Math.max(savedY, commentsSection.offsetTop - 24),
                behavior: "auto",
              });
            });
          } catch {
            // Ignore malformed session state.
          }
        };

        const getCurrentTheme = () => {
          const theme = window.__BX_THEME__?.get?.();
          return theme === "midnight" ? "dark" : "light";
        };

        const syncGiscusTheme = () => {
          const iframe = document.querySelector("iframe.giscus-frame");
          if (!iframe?.contentWindow) return;
          if (iframe.dataset.bxGiscusLoaded !== "true") return;

          iframe.contentWindow.postMessage(
            {
              giscus: {
                setConfig: {
                  theme: getCurrentTheme(),
                },
              },
            },
            "https://giscus.app"
          );
        };

        host.innerHTML = "";

        const script = document.createElement("script");
        script.src = "https://giscus.app/client.js";
        script.async = true;
        script.crossOrigin = "anonymous";
        script.setAttribute("data-repo", giscusConfig.repo);
        script.setAttribute("data-repo-id", giscusConfig.repoId);
        script.setAttribute("data-category", giscusConfig.category);
        script.setAttribute("data-category-id", giscusConfig.categoryId);
        script.setAttribute("data-mapping", giscusConfig.mapping);
        script.setAttribute("data-strict", giscusConfig.strict);
        script.setAttribute(
          "data-reactions-enabled",
          giscusConfig.reactionsEnabled
        );
        script.setAttribute("data-emit-metadata", giscusConfig.emitMetadata);
        script.setAttribute("data-input-position", giscusConfig.inputPosition);
        script.setAttribute("data-theme", getCurrentTheme());
        script.setAttribute("data-lang", giscusConfig.lang);
        script.setAttribute("data-loading", giscusConfig.loading);
        host.appendChild(script);

        const bindFrameLoad = () => {
          const frame = document.querySelector("iframe.giscus-frame");
          if (!frame) return false;
          if (frame.dataset.bxGiscusBound === "true") return true;

          frame.dataset.bxGiscusBound = "true";
          frame.addEventListener("mouseenter", markGiscusInteraction);
          frame.addEventListener("pointerdown", markGiscusInteraction);
          frame.addEventListener("focus", markGiscusInteraction);
          frame.addEventListener("load", () => {
            frame.dataset.bxGiscusLoaded = "true";
            syncGiscusTheme();
          });
          return true;
        };

        const waitForFrame = window.setInterval(() => {
          if (bindFrameLoad()) {
            window.clearInterval(waitForFrame);
          }
        }, 250);

        window.setTimeout(() => window.clearInterval(waitForFrame), 5000);

        if (!window.__BX_GISCUS_THEME_BOUND__) {
          window.addEventListener(themeChangeEvent, syncGiscusTheme);
          window.__BX_GISCUS_THEME_BOUND__ = true;
        }

        if (!window.__BX_GISCUS_RETURN_BOUND__) {
          window.addEventListener("pagehide", persistReturnPosition);
          document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "hidden") {
              persistReturnPosition();
            }
          });
          window.__BX_GISCUS_RETURN_BOUND__ = true;
        }

        if (document.readyState === "complete") {
          restoreReturnPosition();
        } else {
          window.addEventListener("load", restoreReturnPosition, { once: true });
        }
      })();
    </script>
  )
}

<style>
  .comments-shell {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--muted) 18%, transparent),
        color-mix(in srgb, var(--background) 84%, transparent)
      ),
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--accent) 10%, transparent),
        transparent 32%
      );
  }

  .comments-panel :global(.giscus) {
    width: 100%;
  }

  .comments-panel :global(.giscus-frame) {
    width: 100%;
  }
</style>
