---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type ProjectData = CollectionEntry<"projects">["data"];

type Props = {
  project: CollectionEntry<"projects">;
  workId: string;
  /** Prefer root meta when rendering overview */
  meta?: ProjectData;
};

const { project, workId, meta } = Astro.props;
const data = meta ?? project.data;
const {
  title,
  description,
  tags = [],
  status = "active",
  repo,
  demo,
  cover,
  category,
  pubDatetime,
} = data;

const year = pubDatetime ? pubDatetime.getFullYear() : new Date().getFullYear();
const categoryLabel =
  category?.trim() ||
  `${status === "wip" ? "WIP" : status === "archived" ? "ARCHIVE" : "TOOLING"} — ${year}`;
const displayTags = tags.map((t) => t.toUpperCase());
---

<header class="crt-hero">
  <div class="crt-hero-media">
    {
      cover ? (
        <Image
          src={cover}
          alt=""
          widths={[900, 1400]}
          sizes="(max-width: 768px) 100vw, 72rem"
          loading="eager"
        />
      ) : (
        <div class="crt-hero-fallback" aria-hidden="true">
          <span>+ {title.toUpperCase()}</span>
        </div>
      )
    }
    <div class="crt-card-scan" aria-hidden="true"></div>
  </div>

  <div class="crt-hero-body">
    <div class="crt-hero-kicker">
      {workId}&nbsp;&nbsp;·&nbsp;&nbsp;{categoryLabel}&nbsp;&nbsp;·&nbsp;&nbsp;{
        status.toUpperCase()
      }
    </div>
    <h1 class="crt-hero-title">{title}</h1>
    <p class="crt-hero-desc">{description}</p>

    {
      displayTags.length > 0 && (
        <ul class="crt-tags" style="margin-top:1rem">
          {displayTags.map((tag) => (
            <li class="crt-tag">{tag}</li>
          ))}
        </ul>
      )
    }

    <div class="crt-hero-actions">
      {
        repo && (
          <a
            class="crt-btn crt-btn--primary"
            href={repo}
            target="_blank"
            rel="noopener noreferrer"
          >
            ▶ GITHUB
          </a>
        )
      }
      {
        demo && (
          <a
            class="crt-btn"
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
          >
            DEMO / DOCS ↗
          </a>
        )
      }
      <a class="crt-btn" href="/projects/">ALL WORK</a>
    </div>
  </div>
</header>
