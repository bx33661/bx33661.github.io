---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type Props = {
  project: CollectionEntry<"projects">;
  workId: string;
};

const { project, workId } = Astro.props;
const {
  title,
  description,
  tags,
  status,
  repo,
  demo,
  cover,
  category,
  pubDatetime,
} = project.data;

const year = pubDatetime.getFullYear();
const categoryLabel =
  category?.trim() ||
  `${status === "wip" ? "WIP" : status === "archived" ? "ARCHIVE" : "TOOLING"} — ${year}`;
const displayTags = tags.map((t) => t.toUpperCase());
---

<header class="crt-hero">
  {
    cover && (
      <div class="crt-hero-media">
        <Image
          src={cover}
          alt=""
          widths={[900, 1400]}
          sizes="(max-width: 768px) 100vw, 72rem"
          loading="eager"
        />
        <div class="crt-card-scan" aria-hidden="true" />
      </div>
    )
  }

  <div class="crt-hero-body">
    <div class="crt-hero-kicker">
      {workId} · {categoryLabel} · {status.toUpperCase()}
    </div>
    <h1 class="crt-hero-title">{title}</h1>
    <p class="crt-hero-desc">{description}</p>

    {
      displayTags.length > 0 && (
        <ul class="crt-tags" style="margin-top:1rem">
          {displayTags.map((tag) => (
            <li class="crt-tag">{tag}</li>
          ))}
        </ul>
      )
    }

    <div class="crt-hero-actions">
      <a
        class="crt-btn crt-btn--primary"
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
      >
        ▶ GITHUB
      </a>
      {
        demo && (
          <a
            class="crt-btn"
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
          >
            DEMO / DOCS ↗
          </a>
        )
      }
    </div>
  </div>
</header>
