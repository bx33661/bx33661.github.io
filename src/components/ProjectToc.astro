---
/**
 * In-page TOC for CRT docs. Headings are expected as h2/h3 with ids
 * (Astro markdown default). Built client-side so it works with <Content />.
 */
type Props = {
  /** CSS selector of the prose root */
  rootSelector?: string;
};

const { rootSelector = ".crt-prose" } = Astro.props;
---

<nav class="crt-toc" aria-label="On this page" data-toc-root={rootSelector} hidden>
  <div class="crt-toc-label">ON THIS PAGE</div>
  <ol class="crt-toc-list"></ol>
</nav>

<script>
  function buildToc() {
    document.querySelectorAll<HTMLElement>("nav.crt-toc[data-toc-root]").forEach((nav) => {
      const sel = nav.dataset.tocRoot || ".crt-prose";
      const root = nav.closest(".crt-docs-main")?.querySelector(sel) ?? document.querySelector(sel);
      const list = nav.querySelector(".crt-toc-list");
      if (!(root instanceof HTMLElement) || !(list instanceof HTMLOListElement)) return;

      list.innerHTML = "";
      const headings = Array.from(root.querySelectorAll<HTMLElement>("h2[id], h3[id]"));
      if (headings.length < 2) {
        nav.hidden = true;
        return;
      }

      nav.hidden = false;
      for (const h of headings) {
        const li = document.createElement("li");
        li.className = h.tagName === "H3" ? "crt-toc-item crt-toc-item--h3" : "crt-toc-item";
        const a = document.createElement("a");
        a.href = `#${h.id}`;
        a.textContent = h.textContent?.trim() || h.id;
        li.appendChild(a);
        list.appendChild(li);
      }
    });
  }

  buildToc();
  document.addEventListener("astro:page-load", buildToc);
</script>
